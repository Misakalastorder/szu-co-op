    <parent link="middle_2" />
    <child link="middle_3" />
    <axis xyz="0 1 0" />
    <limit lower="0" upper="1.57" effort="1" velocity="1" />
  </joint>

  <link name="middle_4">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.01" />
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4" />
