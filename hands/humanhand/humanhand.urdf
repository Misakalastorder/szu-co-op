  <!-- ============== 大拇指 (thumb) ============== -->
  <!-- 3个可动关节 + 1个固定指尖 -->
  <!-- 拇指根部从掌心偏向y正方向（右手拇指指向y+） -->
  <link name="thumb_1">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.01" />
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4" />
    </inertial>
    <visual>
      <!-- 拇指也沿x轴伸出 -->
