    <child link="middle_1" />
    <axis xyz="0 0 1" />
    <limit lower="-0.174532" upper="0.174532" effort="1" velocity="1" />
  </joint>

  <link name="middle_2">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
